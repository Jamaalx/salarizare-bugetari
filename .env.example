# NVIDIA NIM API for the AI chat widget (/api/chat).
# Get a key from https://build.nvidia.com (free tier available for testing).
# If unset, /api/chat returns 503 NOT_CONFIGURED and the chat widget falls back gracefully.
NVIDIA_API_KEY=

# Override the default model. Defaults to "meta/llama-3.3-70b-instruct".
# Other options: "meta/llama-3.1-405b-instruct", "mistralai/mistral-large-2-instruct"
NVIDIA_MODEL=
